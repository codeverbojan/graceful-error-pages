{
	"name": "codever/graceful-error-pages",
	"description": "Replace WordPress's ugly error screens with branded, professional pages.",
	"type": "wordpress-plugin",
	"version": "1.0.6",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Bojan Josifoski",
			"homepage": "https://bojanjosifoski.com"
		}
	],
	"autoload": {
		"psr-4": {
			"GracefulErrorPages\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"GracefulErrorPages\\Tests\\": "tests/"
		}
	},
	"require": {
		"php": ">=8.0"
	},
	"require-dev": {
		"brain/monkey": "^2.6",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"php-stubs/wordpress-stubs": "^6.0",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"phpstan/extension-installer": "^1.0",
		"phpstan/phpstan": "^2.0",
		"phpunit/phpunit": "^9.6",
		"squizlabs/php_codesniffer": "^3.7",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"wp-coding-standards/wpcs": "^3.0",
		"wp-phpunit/wp-phpunit": "^6.9",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true
		},
		"platform": {
			"php": "8.1.0"
		},
		"sort-packages": true
	},
	"scripts": {
		"lint": "phpcs",
		"lint:fix": "phpcbf",
		"analyze": "phpstan analyze --memory-limit=1G",
		"test": "phpunit --testsuite Unit",
		"check": [
			"@lint",
			"@analyze",
			"@test"
		]
	}
}
