{
	"name": "graceful-error-pages",
	"version": "1.0.6",
	"description": "Replace WordPress's ugly error screens with branded, professional pages.",
	"author": "Bojan Josifoski",
	"license": "GPL-2.0-or-later",
	"private": true,
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"lint:js": "wp-scripts lint-js assets/src",
		"lint:js:fix": "wp-scripts lint-js assets/src --fix",
		"lint:css": "wp-scripts lint-style assets/src/**/*.css",
		"lint:css:fix": "wp-scripts lint-style assets/src/**/*.css --fix",
		"format": "wp-scripts format assets/src",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"env:clean": "wp-env clean all",
		"env:reset": "wp-env destroy && wp-env start",
		"env:cli": "wp-env run cli",
		"plugin-check": "wp-env run cli -- wp plugin check graceful-error-pages",
		"prepare": "husky"
	},
	"devDependencies": {
		"@wordpress/env": "11.5.0",
		"@wordpress/scripts": "32.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.2",
		"playwright": "^1.60.0",
		"tsx": "^4.22.3"
	},
	"lint-staged": {
		"*.php": "vendor/bin/phpcs --no-colors",
		"assets/src/**/*.js": "wp-scripts lint-js",
		"assets/src/**/*.css": "wp-scripts lint-style"
	}
}
